    {
      "name": "Webhook - Banxa (Update status to completed)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.environment.get('webhook_idempotency_key')) {",
              "  pm.environment.set('webhook_idempotency_key', 'demo-update-001');",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('last_webhook_status', body.status || '');",
              "pm.environment.set('last_webhook_idempotency_key', body.idempotency_key || '');"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-IDEMPOTENCY-KEY",
            "value": "{{webhook_idempotency_key}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event\": \"order_completed\",\n  \"order_id\": \"{{onramp_order_id}}\",\n  \"status\": \"success\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/webhooks/banxa",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "webhooks",
            "banxa"
          ]
        }
      },
      "response": []
    },
