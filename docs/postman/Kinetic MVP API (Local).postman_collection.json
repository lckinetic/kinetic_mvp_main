    {
      "name": "Onramp - Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.environment.set('onramp_order_id', body.order_id);",
              "pm.environment.set('onramp_checkout_url', body.checkout_url || '');",
              "pm.test('order_id exists', function () {",
              "  pm.expect(body.order_id).to.be.ok;",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fiat_amount\": 100,\n  \"fiat_currency\": \"GBP\",\n  \"crypto_currency\": \"USDC\",\n  \"wallet_address\": \"0xabc123\",\n  \"blockchain\": \"ethereum\",\n  \"user_email\": \"test@example.com\",\n  \"client_reference\": \"demo-client-ref-001\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/onramp/orders",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "onramp",
            "orders"
          ]
        }
      },
      "response": []
    },
